{
  "suggest.echodocSupport": true,
  "suggest.maxCompleteItemCount": 20,
  "coc.preferences.formatOnSaveFiletypes": ["go","javascript", "typescript", "typescriptreact", "json", "javascriptreact", "typescript.tsx"],
  "diagnostic.errorSign": "",
  "diagnostic.warningSign": "",
  "diagnostic.infoSign": "",
  "languageserver": {
	  "golang": {
		  "command": "gopls",
		  "rootPatterns": [
			  "go.mod", ".vim/", ".git/", ".hg/"
		  ],
		  "filetypes": ["go"]
	  }
  }
}
